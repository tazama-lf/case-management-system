# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Dependency directories
node_modules/

# Build and output directories (NestJS)
dist/
build/

# Coverage directories (Jest)
coverage/
*.lcov
.jest-cache/

# Prisma-specific ignores
prisma/*.db
prisma/*.db-journal

# Generated files (Prisma or other)
/generated/

# TypeScript cache and declaration files
*.tsbuildinfo
*.d.ts
!*.d.cts
!*.d.mts

# Optional npm/Yarn/pnpm cache
.npm
.yarn-integrity
.pnpm-store/

# Optional linting caches
.eslintcache
.stylelintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Environment variable files
.env
.env.*
!.env.example

# NPM configuration (may contain tokens)
.npmrc

# Editor and IDE files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store

# Temporary files
tmp/
temp/
*.bak
*.swp
Thumbs.db