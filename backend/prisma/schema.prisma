generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SystemConfiguration {
  id           String   @id @default(uuid())
  config_key   String   @unique
  config_value Json
  config_type  String
  description  String?
  is_active    Boolean  @default(true)
  created_by   String
  updated_by   String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  version      Int      @default(1)

  @@map("system_configurations")
}

model ConfigurationChangeLog {
  id            String    @id @default(uuid())
  config_id     String
  config_key    String
  old_value     Json?
  new_value     Json
  change_type   String
  changed_by    String
  change_reason String?
  ip_address    String?
  user_agent    String?
  requires_2fa  Boolean   @default(false)
  approved_by   String?
  approval_date DateTime?
  change_status String
  created_at    DateTime  @default(now())

  @@map("configuration_change_logs")
}

model RolePermission {
  id             String   @id @default(uuid())
  role_name      String   @unique
  permissions    Json
  description    String?
  is_system_role Boolean  @default(false)
  is_active      Boolean  @default(true)
  created_by     String
  updated_by     String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("role_permissions")
}

model IntegrationConfig {
  id             String    @id @default(uuid())
  system_name    String    @unique
  endpoint_url   String?
  api_key        String?
  api_secret     String?
  config_data    Json?
  auth_type      String?
  is_enabled     Boolean   @default(true)
  last_tested_at DateTime?
  test_status    String?
  created_by     String
  updated_by     String
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@map("integration_configs")
}

model AuditLog {
  audit_log_id     String   @id @default(uuid()) @db.Uuid
  user_id          String   @db.Uuid
  operation        String   @db.VarChar(50)
  entity_name      String   @db.VarChar(50)
  action_performed String   @db.VarChar(255)
  outcome          String   @db.VarChar(255)
  performed_at     DateTime @default(now()) @db.Timestamp(6)

  @@map("audit_log")
}

model Alert {
  alert_id           String             @id @default(uuid()) @db.Uuid
  tenant_id          String             @db.Uuid
  priority           Priority?          @default(NEW)
  priority_score     Float?
  alert_type         AlertType?
  prediction_outcome PredictionOutcome? @default(TRUE_POSITIVE)
  source             String?            @db.VarChar(50)
  txtp               String?            @db.VarChar(50)
  message            String             @db.VarChar(100)
  alert_data         Json
  transaction        Json
  network_map        Json
  confidence_per     Int
  created_at         DateTime           @default(now()) @db.Timestamp(6)
  case_id            String?            @unique @db.Uuid
  case               Case?              @relation(fields: [case_id], references: [case_id])

  @@map("alerts")
}

model Case {
  case_id              String           @id @default(uuid()) @db.Uuid
  case_creator_user_id String           @db.Uuid
  case_owner_user_id   String?          @db.Uuid
  tenant_id            String           @db.Uuid
  status               CaseStatus
  priority             Priority         @default(NEW)
  created_at           DateTime         @default(now()) @db.Timestamp(6)
  updated_at           DateTime         @updatedAt @db.Timestamp(6)
  parent_id            String?          @db.Uuid
  case_type            CaseType?
  case_creation_type   CaseCreationType
  alert                Alert?
  comments             Comment[]
  tasks                Task[]

  @@map("cases")
}

model Task {
  task_id            String     @id @default(uuid()) @db.Uuid
  case_id            String     @db.Uuid
  status             TaskStatus @default(STATUS_01_UNASSIGNED)
  assigned_user_id   String?    @db.Uuid
  name               String?
  description        String?
  task_type          TaskType?
  candidateGroup     String?    @db.VarChar(50)
  work_queue_id      String?    @db.Uuid
  sla_deadline       DateTime?  @db.Timestamp(6)
  sla_duration_hours Int?
  completed_at       DateTime?  @db.Timestamp(6)
  created_at         DateTime   @default(now()) @db.Timestamp(6)
  updated_at         DateTime   @updatedAt @db.Timestamp(6)
  comments           Comment[]
  evidence           Evidence[]
  reports            Report[]
  case               Case       @relation(fields: [case_id], references: [case_id])
  workQueue          WorkQueue? @relation(fields: [work_queue_id], references: [work_queue_id])

  @@index([work_queue_id])
  @@index([status])
  @@index([sla_deadline])
  @@index([assigned_user_id])
  @@map("tasks")
}

model Comment {
  comment_id String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  note       String
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @updatedAt @db.Timestamp(6)
  case_id    String?  @db.Uuid
  task_id    String?  @db.Uuid
  case       Case?    @relation(fields: [case_id], references: [case_id])
  task       Task?    @relation(fields: [task_id], references: [task_id])

  @@map("comments")
}

model Evidence {
  evidence_id      String   @id @default(uuid()) @db.Uuid
  task_id          String   @db.Uuid
  uploader_user_id String   @db.Uuid
  tenant_id        String   @db.Uuid
  name             String   @db.VarChar(30)
  description      String   @db.VarChar(100)
  type             String   @db.VarChar(30)
  file_path        String
  evidence_hash    String
  uploaded_at      DateTime @default(now()) @db.Timestamp(6)
  task             Task     @relation(fields: [task_id], references: [task_id])

  @@map("evidence")
}

model Report {
  report_id        String     @id @default(uuid()) @db.Uuid
  task_id          String     @db.Uuid
  name             String
  report_type      ReportType
  report_file_path String
  report_hash      String     @db.VarChar(255)
  version          String
  created_at       DateTime   @default(now()) @db.Timestamp(6)
  updated_at       DateTime   @updatedAt @db.Timestamp(6)
  task             Task       @relation(fields: [task_id], references: [task_id])

  @@map("reports")
}

enum Priority {
  NEW
  URGENT
  CRITICAL
  BREACH
}

enum CaseStatus {
  STATUS_00_DRAFT
  STATUS_01_PENDING_CASE_CREATION_APPROVAL
  STATUS_02_READY_FOR_ASSIGNMENT
  STATUS_03_RETURNED
  STATUS_10_ASSIGNED
  STATUS_20_IN_PROGRESS
  STATUS_21_SUSPENDED
  STATUS_22_PENDING_FINAL_APPROVAL
  STATUS_31_PENDING_CASE_REOPENING_APPROVAL
  STATUS_71_AUTOCLOSED_CONFIRMED
  STATUS_72_AUTOCLOSED_REFUTED
  STATUS_81_CLOSED_REFUTED
  STATUS_82_CLOSED_CONFIRMED
  STATUS_83_CLOSED_INCONCLUSIVE
  STATUS_99_ABANDONED
}

enum TaskStatus {
  STATUS_01_UNASSIGNED
  STATUS_10_ASSIGNED
  STATUS_20_IN_PROGRESS
  STATUS_30_COMPLETED
  STATUS_21_BLOCKED
}

enum AlertType {
  FRAUD
  AML
  FRAUD_AND_AML
  NONE
}

enum CaseType {
  FRAUD
  AML
  FRAUD_AND_AML
  NONE
}

enum PredictionOutcome {
  FALSE_POSITIVE
  TRUE_POSITIVE
  FALSE_NEGATIVE
  TRUE_NEGATIVE
}

enum CaseCreationType {
  MANUAL
  AUTOMATIC_SYSTEM
}

enum ReportType {
  SUMMARY
  DETAILED
  FINAL
}

enum TaskType {
  INVESTIGATION
  APPROVAL
  REVIEW
  EVIDENCE_COLLECTION
  REPORT_GENERATION
  CASE_CLOSURE
  ESCALATION
}

enum UserRole {
  ADMIN
  INVESTIGATOR
  SUPERVISOR
  ANALYST
}

enum AssignmentRuleType {
  PRIORITY_BASED
  CASE_TYPE_BASED
  ROUND_ROBIN
  LOAD_BALANCED
  MANUAL
}

model WorkQueue {
  work_queue_id      String                    @id @default(uuid()) @db.Uuid
  name               String                    @db.VarChar(100)
  description        String?                   @db.Text
  tenant_id          String                    @db.Uuid
  is_active          Boolean                   @default(true)
  created_by_user_id String                    @db.Uuid
  created_at         DateTime                  @default(now()) @db.Timestamp(6)
  updated_at         DateTime                  @updatedAt @db.Timestamp(6)
  roles              WorkQueueRole[]
  taskTypes          WorkQueueTaskType[]
  assignmentRules    WorkQueueAssignmentRule[]
  members            WorkQueueMember[]
  tasks              Task[]

  @@unique([tenant_id, name])
  @@index([tenant_id])
  @@index([is_active])
  @@map("work_queues")
}

model WorkQueueRole {
  work_queue_role_id String    @id @default(uuid()) @db.Uuid
  work_queue_id      String    @db.Uuid
  role               UserRole
  created_at         DateTime  @default(now()) @db.Timestamp(6)
  workQueue          WorkQueue @relation(fields: [work_queue_id], references: [work_queue_id], onDelete: Cascade)

  @@unique([work_queue_id, role])
  @@index([work_queue_id])
  @@map("work_queue_roles")
}

model WorkQueueTaskType {
  work_queue_task_type_id String    @id @default(uuid()) @db.Uuid
  work_queue_id           String    @db.Uuid
  task_type               TaskType
  created_at              DateTime  @default(now()) @db.Timestamp(6)
  workQueue               WorkQueue @relation(fields: [work_queue_id], references: [work_queue_id], onDelete: Cascade)

  @@unique([work_queue_id, task_type])
  @@index([work_queue_id])
  @@map("work_queue_task_types")
}

model WorkQueueAssignmentRule {
  assignment_rule_id String             @id @default(uuid()) @db.Uuid
  work_queue_id      String             @db.Uuid
  rule_name          String             @default("Legacy Rule") @db.VarChar(255)
  rule_type          AssignmentRuleType
  rule_config        Json
  trigger_type       String?            @db.VarChar(50)
  conditions         Json?
  actions            Json?
  stop_on_match      Boolean            @default(false)
  priority_order     Int                @default(0)
  is_active          Boolean            @default(true)
  application_count  Int                @default(0)
  last_applied_at    DateTime?          @db.Timestamp(6)
  created_by         String             @default("00000000-0000-0000-0000-000000000000") @db.Uuid
  updated_by         String?            @db.Uuid
  created_at         DateTime           @default(now()) @db.Timestamp(6)
  updated_at         DateTime           @updatedAt @db.Timestamp(6)
  workQueue          WorkQueue          @relation(fields: [work_queue_id], references: [work_queue_id], onDelete: Cascade)

  @@index([work_queue_id])
  @@index([is_active])
  @@index([priority_order])
  @@index([trigger_type])
  @@map("work_queue_assignment_rules")
}

model WorkQueueMember {
  work_queue_member_id String         @id @default(uuid()) @db.Uuid
  work_queue_id        String         @db.Uuid
  user_id              String         @db.Uuid
  assignment_type      AssignmentType @default(MANUAL)
  assigned_by_user_id  String?        @db.Uuid
  assigned_at          DateTime       @default(now()) @db.Timestamp(6)
  updated_at           DateTime       @updatedAt @db.Timestamp(6)
  workQueue            WorkQueue      @relation(fields: [work_queue_id], references: [work_queue_id], onDelete: Cascade)

  @@unique([work_queue_id, user_id])
  @@index([work_queue_id])
  @@index([user_id])
  @@map("work_queue_members")
}

enum AssignmentType {
  MANUAL
  AUTOMATIC
  OVERRIDE
}

enum NotificationChannel {
  EMAIL
  IN_APP
  SMS
  DASHBOARD
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_REASSIGNED
  TASK_UNASSIGNED
  TASK_DUE_SOON
  TASK_OVERDUE
  SLA_WARNING
  SLA_BREACH
  WORK_QUEUE_ADDED
  WORK_QUEUE_REMOVED
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
  RETRYING
  PERMANENT_FAILURE
}

model UserNotificationPreference {
  preference_id        String              @id @default(uuid()) @db.Uuid
  user_id              String              @unique @db.Uuid
  tenant_id            String              @db.Uuid
  email_enabled        Boolean             @default(true)
  in_app_enabled       Boolean             @default(true)
  sms_enabled          Boolean             @default(false)
  dashboard_enabled    Boolean             @default(true)
  phone_number         String?             @db.VarChar(20)
  suppression_settings Json? // NotificationType[] to suppress
  default_channel      NotificationChannel @default(EMAIL)
  created_at           DateTime            @default(now()) @db.Timestamp(6)
  updated_at           DateTime            @updatedAt @db.Timestamp(6)

  @@index([user_id])
  @@index([tenant_id])
  @@map("user_notification_preferences")
}

model NotificationLog {
  notification_log_id String              @id @default(uuid()) @db.Uuid
  user_id             String              @db.Uuid
  tenant_id           String              @db.Uuid
  task_id             String?             @db.Uuid
  case_id             String?             @db.Uuid
  notification_type   NotificationType
  channel             NotificationChannel
  delivery_status     DeliveryStatus      @default(PENDING)
  retry_count         Int                 @default(0)
  max_retries         Int                 @default(5)
  payload             Json // Complete notification payload
  error_message       String?             @db.Text
  sent_at             DateTime?           @db.Timestamp(6)
  read_at             DateTime?           @db.Timestamp(6)
  created_at          DateTime            @default(now()) @db.Timestamp(6)
  updated_at          DateTime            @updatedAt @db.Timestamp(6)

  @@index([user_id, notification_type])
  @@index([task_id])
  @@index([case_id])
  @@index([delivery_status])
  @@index([created_at])
  @@index([user_id, read_at])
  @@map("notification_logs")
}
