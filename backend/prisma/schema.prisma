generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuditLog {
  audit_log_id     String   @id @default(uuid()) @db.Uuid
  user_id          String   @db.Uuid
  operation        String   @db.VarChar(50)
  entity_name      String   @db.VarChar(50)
  action_performed String   @db.VarChar(255)
  outcome          String   @db.VarChar(255)
  performed_at     DateTime @default(now()) @db.Timestamp(6)

  @@map("audit_log")
}

model Alert {
  alert_id           String             @id @default(uuid()) @db.Uuid
  tenant_id          String             @db.Uuid
  priority           Priority?          @default(NEW)
  alert_type         AlertType?
  prediction_outcome PredictionOutcome? @default(FALSE_POSITIVE)
  source             String?            @db.VarChar(50)
  txtp               String?            @db.VarChar(50)
  message            String             @db.VarChar(100)
  alert_data         Json
  transaction        Json
  network_map        Json
  confidence_per     Int
  created_at         DateTime           @default(now()) @db.Timestamp(6)
  case_id            String             @unique @db.Uuid
  case               Case               @relation(fields: [case_id], references: [case_id])
  priority_score     Int?

  @@map("alerts")
}

model Case {
  case_id              String           @id @default(uuid()) @db.Uuid
  case_creator_user_id String           @db.Uuid
  case_owner_user_id   String?          @db.Uuid
  tenant_id            String           @db.Uuid
  status               CaseStatus
  priority             Priority         @default(NEW)
  created_at           DateTime         @default(now()) @db.Timestamp(6)
  updated_at           DateTime         @updatedAt @db.Timestamp(6)
  parent_id            String?          @db.Uuid
  case_type            CaseType?
  case_creation_type   CaseCreationType
  alert                Alert?
  comments             Comment[]
  tasks                Task[]

  @@map("cases")
}

model Task {
  task_id          String     @id @default(uuid()) @db.Uuid
  case_id          String     @db.Uuid
  assigned_user_id String?    @db.Uuid
  name             String?
  description      String?
  created_at       DateTime   @default(now()) @db.Timestamp(6)
  updated_at       DateTime   @updatedAt @db.Timestamp(6)
  status           TaskStatus @default(UNASSIGNED_01)
  comments         Comment[]
  evidence         Evidence[]
  reports          Report[]
  case             Case       @relation(fields: [case_id], references: [case_id])

  @@map("tasks")
}

model Comment {
  comment_id String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  note       String
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @updatedAt @db.Timestamp(6)
  case_id    String?  @db.Uuid
  task_id    String?  @db.Uuid
  case       Case?    @relation(fields: [case_id], references: [case_id])
  task       Task?    @relation(fields: [task_id], references: [task_id])

  @@map("comments")
}

model Evidence {
  evidence_id      String   @id @default(uuid()) @db.Uuid
  task_id          String   @db.Uuid
  uploader_user_id String   @db.Uuid
  tenant_id        String   @db.Uuid
  name             String   @db.VarChar(30)
  description      String   @db.VarChar(100)
  type             String   @db.VarChar(30)
  file_path        String
  evidence_hash    String
  uploaded_at      DateTime @default(now()) @db.Timestamp(6)
  task             Task     @relation(fields: [task_id], references: [task_id])

  @@map("evidence")
}

model Report {
  report_id        String     @id @default(uuid()) @db.Uuid
  task_id          String     @db.Uuid
  name             String
  report_type      ReportType
  report_file_path String
  report_hash      String     @db.VarChar(255)
  version          String
  created_at       DateTime   @default(now()) @db.Timestamp(6)
  updated_at       DateTime   @updatedAt @db.Timestamp(6)
  task             Task       @relation(fields: [task_id], references: [task_id])

  @@map("reports")
}

enum Priority {
  NEW
  URGENT
  CRITICAL
  BREACH
}

enum CaseStatus {
  DRAFT_00
  PENDING_CASE_CREATION_APPROVAL_01
  READY_FOR_ASSIGNMENT_02
  RETURNED_03
  ASSIGNED_10
  IN_PROGRESS_20
  SUSPENDED_21
  PENDING_FINAL_APPROVAL_22
  PENDING_REOPENING_30
  REOPENED_31
  AUTOCLOSED_CONFIRMED_71
  AUTOCLOSED_REFUTED_72
  CLOSED_REFUTED_81
  CLOSED_CONFIRMED_82
  CLOSED_INCONCLUSIVE_83
  ABANDONED_99
}

enum TaskStatus {
  UNASSIGNED_01
  ASSIGNED_10
  IN_PROGRESS_20
  COMPLETED_30
  BLOCKED_21
}

enum CaseType {
  FRAUD
  AML
  FRAUD_AND_AML
}

enum AlertType {
  FRAUD
  AML
  FRAUD_AND_AML
}

enum PredictionOutcome {
  FALSE_POSITIVE
  TRUE_POSITIVE
  FALSE_NEGATIVE
  TRUE_NEGATIVE
}

enum CaseCreationType {
  MANUAL
  AUTOMATIC_SYSTEM
}

enum ReportType {
  SUMMARY
  DETAILED
  FINAL
}
