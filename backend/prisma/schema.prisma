generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/client-cms"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SystemConfiguration {
  id           Int      @id @default(autoincrement())
  config_key   String   @unique
  config_value Json
  config_type  String
  description  String?
  is_active    Boolean  @default(true)
  created_by   String
  updated_by   String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  version      Int      @default(1)

  @@map("system_configurations")
}

model ConfigurationChangeLog {
  id            Int       @id @default(autoincrement())
  config_id     Int
  config_key    String
  old_value     Json?
  new_value     Json
  change_type   String
  changed_by    String
  change_reason String?
  ip_address    String?
  user_agent    String?
  requires_2fa  Boolean   @default(false)
  approved_by   String?
  approval_date DateTime?
  change_status String
  created_at    DateTime  @default(now())

  @@map("configuration_change_logs")
}

model RolePermission {
  id             Int      @id @default(autoincrement())
  role_name      String   @unique
  permissions    Json
  description    String?
  is_system_role Boolean  @default(false)
  is_active      Boolean  @default(true)
  created_by     String
  updated_by     String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("role_permissions")
}

model IntegrationConfig {
  id             Int       @id @default(autoincrement())
  system_name    String    @unique
  endpoint_url   String?
  api_key        String?
  api_secret     String?
  config_data    Json?
  auth_type      String?
  is_enabled     Boolean   @default(true)
  last_tested_at DateTime?
  test_status    String?
  created_by     String
  updated_by     String
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@map("integration_configs")
}

model AuditLog {
  audit_log_id     Int      @id @default(autoincrement())
  user_id          String   @db.Uuid
  operation        String   @db.VarChar(50)
  entity_name      String   @db.VarChar(50)
  action_performed String   @db.VarChar(1000)
  outcome          String   @db.VarChar(255)
  performed_at     DateTime @default(now()) @db.Timestamp(6)

  @@map("audit_log")
}

model Alert {
  alert_id           Int                @id @default(autoincrement())
  tenant_id          String
  priority           Priority?          @default(NEW)
  priority_score     Float?
  alert_type         CaseType?
  prediction_outcome PredictionOutcome? @default(TRUE_POSITIVE)
  source             String?            @db.VarChar(50)
  txtp               String            @db.VarChar(50)
  message            String             @db.VarChar(100)
  alert_data         Json
  transaction        Json
  network_map        Json
  confidence_per     Int
  block_status       String?            @db.VarChar(50)
  block_reason       String?            @db.Text
  created_at         DateTime           @default(now()) @db.Timestamp(6)
  case_id            Int?               @unique
  case               Case?              @relation(fields: [case_id], references: [case_id])

  @@map("alerts")
}

model Case {
  case_id              Int              @id @default(autoincrement())
  case_creator_user_id String           @db.Uuid
  case_owner_user_id   String?          @db.Uuid
  tenant_id            String
  status               CaseStatus
  priority             Priority         @default(NEW)
  created_at           DateTime         @default(now()) @db.Timestamp(6)
  updated_at           DateTime         @updatedAt @db.Timestamp(6)
  parent_id            Int?
  case_type            CaseType?
  case_creation_type   CaseCreationType
  alert                Alert?
  comments             Comment[]
  tasks                Task[]
  evidence             Evidence[]
  transactionProfiles  TransactionProfile[]

  @@map("cases")
}

model Task {
  task_id            Int        @id @default(autoincrement())
  case_id            Int
  tenant_id          String
  status             TaskStatus @default(STATUS_01_UNASSIGNED)
  assigned_user_id   String?    @db.Uuid
  name               String?
  description        String?
  investigationNotes String? @db.Text
  task_type          TaskType?
  candidateGroup     String?    @db.VarChar(50)
  sla_deadline       DateTime?  @db.Timestamp(6)
  sla_duration_hours Int?
  completed_at       DateTime?  @db.Timestamp(6)
  created_at         DateTime   @default(now()) @db.Timestamp(6)
  updated_at         DateTime   @updatedAt @db.Timestamp(6)
  comments           Comment[]
  evidence           Evidence[]
  reports            Report[]
  case               Case       @relation(fields: [case_id], references: [case_id])

  @@index([status])
  @@index([sla_deadline])
  @@index([assigned_user_id])
  @@map("tasks")
}

model Comment {
  comment_id Int      @id @default(autoincrement())
  user_id    String   @db.Uuid
  tenant_id  String
  note       String
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @updatedAt @db.Timestamp(6)
  case_id    Int?
  task_id    Int?
  case       Case?    @relation(fields: [case_id], references: [case_id])
  task       Task?    @relation(fields: [task_id], references: [task_id])

  @@map("comments")
}

model Evidence {
  evidence_id      String   @id @db.VarChar(255)
  task_id          Int
  case_id          Int    
  uploader_user_id String   @db.Uuid
  tenant_id        String   
  name             String   @db.VarChar(255)
  description      String?   @db.VarChar(1000)
  type             String   @db.VarChar(50)
  file_path        String
  file_size        BigInt?
  file_type        String?  @db.VarChar(255)
  evidence_hash    String
  metadata         Json?
  uploaded_at      DateTime @default(now()) @db.Timestamp(6)
  task             Task     @relation(fields: [task_id], references: [task_id])
  case             Case?    @relation(fields: [case_id], references: [case_id])

  @@index([case_id])
  @@index([evidence_hash])
  @@map("evidence")
}

model Report {
  report_id        Int        @id @default(autoincrement())
  task_id          Int
  name             String
  report_type      ReportType
  report_file_path String
  report_hash      String     @db.VarChar(255)
  version          Int        @default(1)
  locked           Boolean    @default(false)
  created_at       DateTime   @default(now()) @db.Timestamp(6)
  updated_at       DateTime   @updatedAt @db.Timestamp(6)
  task             Task       @relation(fields: [task_id], references: [task_id])

  @@map("reports")
}

model TransactionProfile {
  profile_id      String   @id @default(uuid())
  case_id         Int   
  generated_by    String   @db.Uuid
  generated_at    DateTime @default(now())
  filters         Json?
  metrics         Json?
  outliers        Json?
  summary_table   Json?
  notes           String?  @db.Text
  visualization   String?
  detected_anomalies Json?
  case            Case     @relation(fields: [case_id], references: [case_id])
}

model TransactionData {
  transactionId Int      @id @default(autoincrement())
  tenantId      String
  endToEndId    String   @db.VarChar(50)
  transactionData Json
  createdAt     DateTime @default(now()) @db.Timestamp(6)

  @@map("transaction_data")
}

model ReferenceId {
  id   Int      @id @default(autoincrement())
  txTp String   @db.VarChar(50) @unique
  referenceIdName   String @db.VarChar(50)
  createdAt  DateTime @default(now()) @db.Timestamp(6)

  @@map("reference_ids")
}

enum Priority {
  NEW
  URGENT
  CRITICAL
  BREACH
}

enum CaseStatus {
  STATUS_00_DRAFT
  STATUS_01_PENDING_CASE_CREATION_APPROVAL
  STATUS_02_READY_FOR_ASSIGNMENT
  STATUS_03_RETURNED
  STATUS_10_ASSIGNED
  STATUS_20_IN_PROGRESS
  STATUS_21_SUSPENDED
  STATUS_22_PENDING_FINAL_APPROVAL
  STATUS_31_PENDING_CASE_REOPENING_APPROVAL
  STATUS_71_AUTOCLOSED_CONFIRMED
  STATUS_72_AUTOCLOSED_REFUTED
  STATUS_81_CLOSED_REFUTED
  STATUS_82_CLOSED_CONFIRMED
  STATUS_83_CLOSED_INCONCLUSIVE
  STATUS_99_ABANDONED
  STATUS_84_COMPLETED
}

enum TaskStatus {
  STATUS_01_UNASSIGNED
  STATUS_10_ASSIGNED
  STATUS_20_IN_PROGRESS
  STATUS_30_COMPLETED
  STATUS_21_BLOCKED
}

enum CaseType {
  FRAUD
  AML
  FRAUD_AND_AML
}

enum PredictionOutcome {
  FALSE_POSITIVE
  TRUE_POSITIVE
  FALSE_NEGATIVE
  TRUE_NEGATIVE
}

enum CaseCreationType {
  MANUAL
  AUTOMATIC_SYSTEM
}

enum ReportType {
  SUMMARY
  DETAILED
  FINAL
}

enum TaskType {
  INVESTIGATION
  APPROVAL
  REVIEW
  EVIDENCE_COLLECTION
  REPORT_GENERATION
  CASE_CLOSURE
  ESCALATION
  SAR_STR_FILING
}

enum UserRole {
  ADMIN
  INVESTIGATOR
  SUPERVISOR
  ANALYST
}

enum AssignmentRuleType {
  PRIORITY_BASED
  CASE_TYPE_BASED
  ROUND_ROBIN
  LOAD_BALANCED
  MANUAL
}
enum AssignmentType {
  MANUAL
  AUTOMATIC
  OVERRIDE
}

enum NotificationChannel {
  EMAIL
  IN_APP
  SMS
  DASHBOARD
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_REASSIGNED
  TASK_UNASSIGNED
  TASK_DUE_SOON
  TASK_OVERDUE
  SLA_WARNING
  SLA_BREACH
  WORK_QUEUE_ADDED
  WORK_QUEUE_REMOVED
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
  RETRYING
  PERMANENT_FAILURE
}

model UserNotificationPreference {
  preference_id        Int                 @id @default(autoincrement())
  user_id              String              @unique @db.Uuid
  tenant_id            String
  email_enabled        Boolean             @default(true)
  in_app_enabled       Boolean             @default(true)
  sms_enabled          Boolean             @default(false)
  dashboard_enabled    Boolean             @default(true)
  phone_number         String?             @db.VarChar(20)
  suppression_settings Json? // NotificationType[] to suppress
  default_channel      NotificationChannel @default(EMAIL)
  created_at           DateTime            @default(now()) @db.Timestamp(6)
  updated_at           DateTime            @updatedAt @db.Timestamp(6)

  @@index([user_id])
  @@index([tenant_id])
  @@map("user_notification_preferences")
}

model NotificationLog {
  notification_log_id Int                 @id @default(autoincrement())
  user_id             String              @db.Uuid
  tenant_id           String
  task_id             Int?
  case_id             Int?
  notification_type   NotificationType
  channel             NotificationChannel
  delivery_status     DeliveryStatus      @default(PENDING)
  retry_count         Int                 @default(0)
  max_retries         Int                 @default(5)
  payload             Json // Complete notification payload
  error_message       String?             @db.Text
  sent_at             DateTime?           @db.Timestamp(6)
  read_at             DateTime?           @db.Timestamp(6)
  created_at          DateTime            @default(now()) @db.Timestamp(6)
  updated_at          DateTime            @updatedAt @db.Timestamp(6)

  @@index([user_id, notification_type])
  @@index([task_id])
  @@index([case_id])
  @@index([delivery_status])
  @@index([created_at])
  @@index([user_id, read_at])
  @@map("notification_logs")
}

model AsyncTask {
  task_id        Int             @id @default(autoincrement())
  task_type      String          @db.VarChar(50) // 'EMAIL', 'SMS', 'WEBHOOK', etc.
  status         AsyncTaskStatus @default(PENDING)
  payload        Json            // Email details: {to, subject, html, metadata}
  max_retries    Int             @default(5)
  retry_count    Int             @default(0)
  next_retry_at  DateTime?       @db.Timestamp(6)
  created_at     DateTime        @default(now()) @db.Timestamp(6)
  updated_at     DateTime        @updatedAt @db.Timestamp(6)
  created_by     String?         @db.VarChar(100) // User ID or 'SYSTEM'

  @@index([status])
  @@index([task_type])
  @@index([next_retry_at])
  @@index([created_at])
  @@index([status, task_type, next_retry_at])
  @@map("async_tasks")
}

enum AsyncTaskStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model EventLog {
  event_log_id     Int      @id @default(autoincrement())
  user_id          String   @db.Uuid
  operation        String   @db.VarChar(50)
  entity_name      String   @db.VarChar(50)
  action_performed String   @db.VarChar(1000)
  outcome          String   @db.VarChar(255)
  performed_at     DateTime @default(now()) @db.Timestamp(6)

  @@map("event_log")
}

model TaskHistory {
  task_history_id     Int   @id @default(autoincrement())
  user_id          String   @db.Uuid
  operation        String   @db.VarChar(50)
  entity_name      String   @db.VarChar(50)
  action_performed String   @db.VarChar(1000)
  case_id          Int
  task_id          Int
  performed_at     DateTime @default(now()) @db.Timestamp(6)

  @@map("task_history")
}

model CaseHistory {
  case_history_id     Int      @id @default(autoincrement())
  user_id          String   @db.Uuid
  operation        String   @db.VarChar(50)
  entity_name      String   @db.VarChar(50)
  action_performed String   @db.VarChar(1000)
  case_id          Int
  performed_at     DateTime @default(now()) @db.Timestamp(6)

  @@map("case_history")
}

model filters {
  filter_Id    Int      @id @default(autoincrement())
  user_Id      String   @db.Uuid
  filter_type  String   @db.VarChar(50)
  user_filters String   @db.Text
  created_at   DateTime @default(now()) @db.Timestamp(6)
  updated_at   DateTime @updatedAt @db.Timestamp(6)
}