<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://www.tazama.org/cms">

    <process id="caseManagementProcess" name="NestJS Case Management Process" isExecutable="true">

        <!-- Start Event -->
        <startEvent id="startEvent" name="Case Initiated">
            <extensionElements>
                <flowable:formProperty id="caseId" name="Case ID" type="string" required="true"/>
                <flowable:formProperty id="tenantId" name="Tenant ID" type="string" required="true"/>
                <flowable:formProperty id="caseType" name="Case Type" type="string" required="false"/>
                <flowable:formProperty id="caseStatus" name="Case Status" type="string" default="STATUS_00_DRAFT"/>
                <flowable:formProperty id="isTriageDisabled" name="Is Triage Disabled" type="boolean" default="false"/>
                <flowable:formProperty id="creationType" name="Creation Type" type="string" required="true"/>
                <flowable:formProperty id="creatorRole" name="Creator Role" type="string" default="SUPERVISOR"/>
            </extensionElements>
        </startEvent>

        <!-- Triage is DISABLED -->
        <exclusiveGateway id="triageGateway" name="Triage Check"/>

        <!-- CASE ASSIGNMENT LOGIC -->
        <userTask id="completeCaseCreation" name="Complete New Case"
                  flowable:candidateGroups="investigations"
                  flowable:category="CASE_CREATION">
            <documentation>Complete case creation and prepare for assignment</documentation>
            <extensionElements>
                <flowable:formProperty id="autoCloseEligible" name="Autoclose Eligible" type="boolean"/>
                <flowable:formProperty id="caseType" name="Case Type" type="string" required="true">
                    <flowable:value id="FRAUD" name="Fraud"/>
                    <flowable:value id="AML" name="AML"/>
                    <flowable:value id="FRAUD_AND_AML" name="Fraud and AML"/>
                </flowable:formProperty>
                <flowable:formProperty id="casePriority" name="Case Priority" type="enum" default="NEW">
                    <flowable:value id="NEW" name="New"/>
                    <flowable:value id="URGENT" name="Urgent"/>
                    <flowable:value id="CRITICAL" name="Critical"/>
                    <flowable:value id="BREACH" name="Breach"/>
                </flowable:formProperty>
            </extensionElements>
        </userTask>

        <!-- Creation Type Gateway -->
        <exclusiveGateway id="creationTypeGateway" name="Creation Type Check"/>

        <!-- AUTOMATIC CREATION PATH -->
        <exclusiveGateway id="autoCloseGateway" name="Auto Close Check"/>

        <!-- Autoclose Task (Manual completion in NestJS) -->
        <!-- <userTask id="performAutoclose" name="Auto Close"
                  flowable:assignee="system">
            <documentation>System task to handle autoclose - complete via NestJS API</documentation>
            <extensionElements>
                <flowable:formProperty id="autoCloseType" name="Autoclose Type" 
                                       type="enum" readable="false" writable="false">
                    <flowable:value id="STATUS_82_CLOSED_CONFIRMED" name="STATUS_82_CLOSED_CONFIRMED"/>
                    <flowable:value id="STATUS_81_CLOSED_REFUTED" name="STATUS_81_CLOSED_REFUTED"/>
                    <flowable:value id="STATUS_83_CLOSED_INCONCLUSIVE" name="STATUS_83_CLOSED_INCONCLUSIVE"/>
                </flowable:formProperty>
                <flowable:formProperty id="autoCloseReason" name="Autoclose Reason" type="string"/>
            </extensionElements>
        </userTask> -->
        
        <endEvent id="endAutoClose" name="Case Autoclosed"/>

        <!-- CASE STATUS GATEWAY -->
        <exclusiveGateway id="caseStatusGateway" name="Case Status Check"/>

        <!-- MANUAL CREATION PATH -->
        <exclusiveGateway id="roleGateway" name="Creator Role Check"/>

        <!-- SUPERVISOR APPROVAL PATH -->
        <userTask id="approveCaseCreation" name="Approve Case Creation"
                  flowable:candidateGroups="supervisors">
            <documentation>Supervisor approves manual case creation</documentation>
            <extensionElements>
                <flowable:formProperty id="creationApproval" name="Approval Decision"
                                       type="enum" required="true">
                    <flowable:value id="approve" name="Approve"/>
                    <flowable:value id="reject" name="Reject"/>
                </flowable:formProperty>
                <flowable:formProperty id="creationComments" name="Comments" type="string"/>
            </extensionElements>
        </userTask>

        <exclusiveGateway id="creationApprovalGateway" name="Creation Approved?"/>

        <!-- CASE TYPE ROUTING -->
        <exclusiveGateway id="investigationRoutingGateway" name="Investigation Type Routing"/>

        <!-- SINGLE INVESTIGATION TASK (for FRAUD or AML only) -->
        <userTask id="investigateCase" name="Investigate Case"
                  flowable:candidateGroups="investigations">
            <documentation>Investigation task for single type cases (FRAUD or AML only)</documentation>
            <extensionElements>
                <flowable:formProperty id="investigationNotes" name="Investigation Notes" type="string"/>
                <flowable:formProperty id="investigationAction" name="Action"
                                       type="enum" required="true">
                    <flowable:value id="inProgress" name="Mark In Progress"/>
                    <flowable:value id="complete" name="Complete Investigation"/>
                    <flowable:value id="suspend" name="Suspend Case"/>
                    <flowable:value id="requestClosure" name="Request Closure"/>
                    <flowable:value id="returnCase" name="Return Case"/>
                </flowable:formProperty>
                <flowable:formProperty id="recommendedOutcome" name="Recommended Outcome" type="enum">
                    <flowable:value id="STATUS_81_CLOSED_REFUTED" name="Closed - Refuted"/>
                    <flowable:value id="STATUS_82_CLOSED_CONFIRMED" name="Closed - Confirmed"/>
                    <flowable:value id="STATUS_83_CLOSED_INCONCLUSIVE" name="Closed - Inconclusive"/>
                </flowable:formProperty>
            </extensionElements>
        </userTask>

        <!-- PARALLEL GATEWAY FOR FRAUD_AND_AML -->
        <parallelGateway id="fraudAmlSplitGateway" name="Split Fraud and AML Investigation"/>

        <!-- FRAUD INVESTIGATION TASK -->
        <userTask id="investigateFraud" name="Investigate Fraud"
                  flowable:candidateGroups="investigations">
            <documentation>Fraud investigation task for FRAUD_AND_AML cases</documentation>
            <extensionElements>
                <flowable:formProperty id="fraudInvestigationNotes" name="Fraud Investigation Notes" type="string"/>
                <flowable:formProperty id="fraudInvestigationAction" name="Fraud Action"
                                       type="enum" required="true">
                    <flowable:value id="inProgress" name="Mark In Progress"/>
                    <flowable:value id="complete" name="Complete Investigation"/>
                    <flowable:value id="suspend" name="Suspend Case"/>
                    <flowable:value id="requestClosure" name="Request Closure"/>
                    <flowable:value id="returnCase" name="Return Case"/>
                </flowable:formProperty>
                <flowable:formProperty id="fraudRecommendedOutcome" name="Fraud Recommended Outcome" type="enum">
                    <flowable:value id="STATUS_81_CLOSED_REFUTED" name="Closed - Refuted"/>
                    <flowable:value id="STATUS_82_CLOSED_CONFIRMED" name="Closed - Confirmed"/>
                    <flowable:value id="STATUS_83_CLOSED_INCONCLUSIVE" name="Closed - Inconclusive"/>
                </flowable:formProperty>
            </extensionElements>
        </userTask>

        <!-- AML INVESTIGATION TASK -->
        <userTask id="investigateAml" name="Investigate AML"
                  flowable:candidateGroups="investigations">
            <documentation>AML investigation task for FRAUD_AND_AML cases</documentation>
            <extensionElements>
                <flowable:formProperty id="amlInvestigationNotes" name="AML Investigation Notes" type="string"/>
                <flowable:formProperty id="amlInvestigationAction" name="AML Action"
                                       type="enum" required="true">
                    <flowable:value id="inProgress" name="Mark In Progress"/>
                    <flowable:value id="complete" name="Complete Investigation"/>
                    <flowable:value id="suspend" name="Suspend Case"/>
                    <flowable:value id="requestClosure" name="Request Closure"/>
                    <flowable:value id="returnCase" name="Return Case"/>
                </flowable:formProperty>
                <flowable:formProperty id="amlRecommendedOutcome" name="AML Recommended Outcome" type="enum">
                    <flowable:value id="STATUS_81_CLOSED_REFUTED" name="Closed - Refuted"/>
                    <flowable:value id="STATUS_82_CLOSED_CONFIRMED" name="Closed - Confirmed"/>
                    <flowable:value id="STATUS_83_CLOSED_INCONCLUSIVE" name="Closed - Inconclusive"/>
                </flowable:formProperty>
            </extensionElements>
        </userTask>

        <!-- PARALLEL GATEWAY TO JOIN INVESTIGATIONS -->
        <parallelGateway id="fraudAmlJoinGateway" name="Join Fraud and AML Investigation"/>

        <!-- Investigation Decision Gateway -->
        <exclusiveGateway id="investigationDecisionGateway" name="Investigation Action"/>

        <!-- CASE CLOSURE APPROVAL PATH -->
        <userTask id="supervisorApproval" name="Approve Case Closure"
                  flowable:candidateGroups="supervisors">
            <documentation>Supervisor reviews and approves or rejects the case closure</documentation>
            <extensionElements>
                <flowable:formProperty id="approvalDecision" name="Approval Decision"
                                       type="enum" required="true">
                    <flowable:value id="approve" name="Approve"/>
                    <flowable:value id="reject" name="Reject"/>
                    <!-- <flowable:value id="returnForReview" name="Return for Review"/> -->
                </flowable:formProperty>
                <flowable:formProperty id="finalOutcome" name="Final Outcome"
                                       type="enum" required="true">
                    <flowable:value id="STATUS_81_CLOSED_REFUTED" name="Closed - Refuted"/>
                    <flowable:value id="STATUS_82_CLOSED_CONFIRMED" name="Closed - Confirmed"/>
                    <flowable:value id="STATUS_83_CLOSED_INCONCLUSIVE" name="Closed - Inconclusive"/>
                </flowable:formProperty>
                <flowable:formProperty id="supervisorComments" name="Supervisor Comments" type="string"/>
                <!-- <flowable:formProperty id="qualityScore" name="Quality Score" type="long"/> -->
            </extensionElements>
        </userTask>

        <!-- Approval Decision Gateway -->
        <exclusiveGateway id="approvalDecisionGateway" name="Approval Decision"/>

        <!-- SAR/STR Filing Decision Gateway -->
        <exclusiveGateway id="sarStrDecisionGateway" name="SAR/STR Filing Required"/>

        <!-- SAR/STR Filing Task -->
        <userTask id="fileSarStr" name="File SAR/STR Report"
                  flowable:candidateGroups="compliance">
            <documentation>File Suspicious Activity Report (SAR) or Suspicious Transaction Report (STR) for confirmed cases</documentation>
            <extensionElements>
                <flowable:formProperty id="sarStrAction" name="Action"
                                       type="enum" required="true">
                    <flowable:value id="inProgress" name="Keep Working"/>
                    <flowable:value id="complete" name="Complete Filing"/>
                </flowable:formProperty>
            </extensionElements>
        </userTask>

        <!-- SAR/STR Completion Decision Gateway -->
        <exclusiveGateway id="sarStrCompletionGateway" name="SAR/STR Action Decision"/>

        <!-- Case Reopening Support -->
        <userTask id="reopenCase" name="Reopen Case"
                  flowable:candidateGroups="supervisors">
            <documentation>Supervisor can reopen a closed case</documentation>
            <extensionElements>
                <flowable:formProperty id="reopenReason" name="Reason for Reopening" type="string" required="true"/>
                <flowable:formProperty id="newAssignee" name="Reassign To" type="string"/>
                <flowable:formProperty id="reopenNotes" name="Reopening Notes" type="string"/>
            </extensionElements>
        </userTask>

        <!-- End Events -->
        <endEvent id="endSuccess" name="Case Workflow Complete"/>
        <endEvent id="endApproved" name="Case Closed"/>
        <endEvent id="endRejected" name="Case Rejected"/>
        <endEvent id="endSuspended" name="Case Suspended"/>
        <endEvent id="endAbandoned" name="Case Abandoned"/>

        <!-- SEQUENCE FLOWS -->

        <!-- Initial routing -->
        <sequenceFlow id="flowStart" sourceRef="startEvent" targetRef="triageGateway"/>

        <sequenceFlow id="flowTriageBypass" sourceRef="triageGateway" targetRef="completeCaseCreation">
            <conditionExpression xsi:type="tFormalExpression">
                ${isTriageDisabled == false}
            </conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flowTriageDisabled" sourceRef="triageGateway" targetRef="investigationRoutingGateway">
            <conditionExpression xsi:type="tFormalExpression">
                ${isTriageDisabled == true}
            </conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flowToCreationTypeGateway" sourceRef="completeCaseCreation" targetRef="creationTypeGateway"/>

        <!-- Automatic creation path -->
        <sequenceFlow id="flowAutomatic" sourceRef="creationTypeGateway" targetRef="autoCloseGateway">
            <conditionExpression xsi:type="tFormalExpression">
                ${creationType == 'AUTOMATIC_SYSTEM'}
            </conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flowAutoclose" sourceRef="autoCloseGateway" targetRef="endAutoClose">
            <conditionExpression xsi:type="tFormalExpression">
                ${autoCloseEligible == true}
            </conditionExpression>
        </sequenceFlow>

        <!-- <sequenceFlow id="flowAutocloseEnd" sourceRef="performAutoclose" targetRef="endAutoclose"/> -->

        <!-- From autoclose to case creation for non-eligible cases -->
        <sequenceFlow id="flowAutocloseToCreation" sourceRef="autoCloseGateway" targetRef="investigationRoutingGateway">
            <conditionExpression xsi:type="tFormalExpression">
                ${autoCloseEligible == false}
            </conditionExpression>
        </sequenceFlow>

        <!-- Manual creation path -->
        <sequenceFlow id="flowManual" sourceRef="creationTypeGateway" targetRef="caseStatusGateway">
            <conditionExpression xsi:type="tFormalExpression">
                ${creationType == 'MANUAL'}
            </conditionExpression>
        </sequenceFlow>

        <!-- Case status routing for manual creation -->
        <sequenceFlow id="flowDraftCase" sourceRef="caseStatusGateway" targetRef="roleGateway">
            <conditionExpression xsi:type="tFormalExpression">
                ${caseStatus == 'STATUS_00_DRAFT'}
            </conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flowNonDraftCase" sourceRef="caseStatusGateway" targetRef="roleGateway">
            <conditionExpression xsi:type="tFormalExpression">
                ${caseStatus != 'STATUS_00_DRAFT'}
            </conditionExpression>
        </sequenceFlow>

        <!-- DRAFT cases: All roles go directly to case creation (no approval needed) -->
        <sequenceFlow id="flowDraftCases" sourceRef="roleGateway" targetRef="completeCaseCreation">
            <conditionExpression xsi:type="tFormalExpression">
                ${caseStatus == 'STATUS_00_DRAFT'}
            </conditionExpression>
        </sequenceFlow>

        <!-- NON-DRAFT cases: Supervisor goes directly to investigation -->
        <sequenceFlow id="flowSupervisorNonDraft" sourceRef="roleGateway" targetRef="investigationRoutingGateway">
            <conditionExpression xsi:type="tFormalExpression">
                ${creatorRole == 'SUPERVISOR' &amp;&amp; caseStatus != 'STATUS_00_DRAFT'}
            </conditionExpression>
        </sequenceFlow>

        <!-- NON-DRAFT cases: Investigator needs approval -->
        <sequenceFlow id="flowInvestigatorNonDraft" sourceRef="roleGateway" targetRef="approveCaseCreation">
            <conditionExpression xsi:type="tFormalExpression">
                ${creatorRole == 'INVESTIGATOR' &amp;&amp; caseStatus != 'STATUS_00_DRAFT'}
            </conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flowFromApproval" sourceRef="approveCaseCreation" targetRef="creationApprovalGateway"/>

        <!-- After approval for NON-DRAFT investigator cases - go directly to investigation -->
        <sequenceFlow id="flowCreationApproved" sourceRef="creationApprovalGateway" targetRef="investigationRoutingGateway">
            <conditionExpression xsi:type="tFormalExpression">
                ${creationApproval == 'approve'}
            </conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flowCreationRejected" sourceRef="creationApprovalGateway" targetRef="endRejected">
            <conditionExpression xsi:type="tFormalExpression">
                ${creationApproval == 'reject'}
            </conditionExpression>
        </sequenceFlow>

        <!-- Investigation routing based on case type -->
        <sequenceFlow id="flowSingleTypeInvestigation" sourceRef="investigationRoutingGateway" targetRef="investigateCase">
            <conditionExpression xsi:type="tFormalExpression">
                ${caseType == 'FRAUD' || caseType == 'AML'}
            </conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flowFraudAndAmlInvestigation" sourceRef="investigationRoutingGateway" targetRef="fraudAmlSplitGateway">
            <conditionExpression xsi:type="tFormalExpression">
                ${caseType == 'FRAUD_AND_AML'}
            </conditionExpression>
        </sequenceFlow>

        <!-- Parallel flows for FRAUD_AND_AML -->
        <sequenceFlow id="flowToFraudInvestigation" sourceRef="fraudAmlSplitGateway" targetRef="investigateFraud"/>
        <sequenceFlow id="flowToAmlInvestigation" sourceRef="fraudAmlSplitGateway" targetRef="investigateAml"/>

        <!-- Join parallel flows -->
        <sequenceFlow id="flowFromFraudInvestigation" sourceRef="investigateFraud" targetRef="fraudAmlJoinGateway"/>
        <sequenceFlow id="flowFromAmlInvestigation" sourceRef="investigateAml" targetRef="fraudAmlJoinGateway"/>

        <!-- From join gateway to decision -->
        <sequenceFlow id="flowFromJoinToDecision" sourceRef="fraudAmlJoinGateway" targetRef="investigationDecisionGateway"/>

        <!-- Investigation decision routing -->
        <sequenceFlow id="flowFromInvestigation" sourceRef="investigateCase" targetRef="investigationDecisionGateway"/>

        <!-- Back to investigation for in progress -->
        <sequenceFlow id="flowInProgress" sourceRef="investigationDecisionGateway" targetRef="investigationRoutingGateway">
            <conditionExpression xsi:type="tFormalExpression">
                ${investigationAction == 'inProgress' || fraudInvestigationAction == 'inProgress' || amlInvestigationAction == 'inProgress'}
            </conditionExpression>
        </sequenceFlow>

        <!-- Request closure -->
        <sequenceFlow id="flowRequestClosure" sourceRef="investigationDecisionGateway" targetRef="supervisorApproval">
            <conditionExpression xsi:type="tFormalExpression">
                ${investigationAction == 'requestClosure' || (fraudInvestigationAction == 'requestClosure' &amp;&amp; amlInvestigationAction == 'requestClosure')}
            </conditionExpression>
        </sequenceFlow>

        <!-- Suspend case -->
        <sequenceFlow id="flowSuspend" sourceRef="investigationDecisionGateway" targetRef="endSuspended">
            <conditionExpression xsi:type="tFormalExpression">
                ${investigationAction == 'suspend' || fraudInvestigationAction == 'suspend' || amlInvestigationAction == 'suspend'}
            </conditionExpression>
        </sequenceFlow>

        <!-- Return case -->
        <sequenceFlow id="flowReturn" sourceRef="investigationDecisionGateway" targetRef="investigationRoutingGateway">
            <conditionExpression xsi:type="tFormalExpression">
                ${investigationAction == 'returnCase' || fraudInvestigationAction == 'returnCase' || amlInvestigationAction == 'returnCase'}
            </conditionExpression>
        </sequenceFlow>

        <!-- Complete without approval -->
        <sequenceFlow id="flowComplete" sourceRef="investigationDecisionGateway" targetRef="endSuccess">
            <conditionExpression xsi:type="tFormalExpression">
                ${investigationAction == 'complete' || (fraudInvestigationAction == 'complete' &amp;&amp; amlInvestigationAction == 'complete')}
            </conditionExpression>
        </sequenceFlow>

        <!-- Closure approval workflow -->
        <sequenceFlow id="flowFromSupervisorApproval" sourceRef="supervisorApproval" targetRef="approvalDecisionGateway"/>

        <sequenceFlow id="flowApprove" sourceRef="approvalDecisionGateway" targetRef="sarStrDecisionGateway">
            <conditionExpression xsi:type="tFormalExpression">
                ${approvalDecision == 'approve'}
            </conditionExpression>
        </sequenceFlow>
        <!-- SAR/STR Filing flows -->
        <sequenceFlow id="flowRequiresSarStr" sourceRef="sarStrDecisionGateway" targetRef="fileSarStr">
            <conditionExpression xsi:type="tFormalExpression">
                ${finalOutcome == 'STATUS_82_CLOSED_CONFIRMED'}
            </conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flowNoSarStrRequired" sourceRef="sarStrDecisionGateway" targetRef="endApproved">
            <conditionExpression xsi:type="tFormalExpression">
                ${finalOutcome != 'STATUS_82_CLOSED_CONFIRMED'}
            </conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flowFromSarStr" sourceRef="fileSarStr" targetRef="sarStrCompletionGateway"/>

        <!-- SAR/STR Completion Decision flows -->
        <sequenceFlow id="flowSarStrInProgress" sourceRef="sarStrCompletionGateway" targetRef="fileSarStr">
            <conditionExpression xsi:type="tFormalExpression">
                ${sarStrAction == 'inProgress'}
            </conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flowSarStrComplete" sourceRef="sarStrCompletionGateway" targetRef="endApproved">
            <conditionExpression xsi:type="tFormalExpression">
                ${sarStrAction == 'complete'}
            </conditionExpression>
        </sequenceFlow>
        
        <sequenceFlow id="flowReject" sourceRef="approvalDecisionGateway" targetRef="investigationRoutingGateway">
            <conditionExpression xsi:type="tFormalExpression">
                ${approvalDecision == 'reject'}
            </conditionExpression>
        </sequenceFlow>

    </process>

</definitions>