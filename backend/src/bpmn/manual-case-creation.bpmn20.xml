<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="http://com.dryrun.cmis">

  <process id="manualCaseCreationProcess" name="Manual Case Creation Process" isExecutable="true">

    <!-- Start -->
    <startEvent id="startEvent" name="Manual Case Created"/>

    <!-- Role gateway -->
    <exclusiveGateway id="roleGateway" name="Role Check"/>

    <!-- Supervisor path -->
    <userTask id="investigateCase" name="Investigate Case"
              flowable:candidateGroups="investigator"
              flowable:assignee="${assigneeId}"
              />

    <!-- Analyst/other path -->
    <userTask id="approveCase" name="Approve Case Creation"
              flowable:candidateGroups="supervisors"/>

    <!-- End -->
    <endEvent id="endEvent" name="Case Workflow Complete"/>

    <!-- Flows -->
    <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="roleGateway"/>
    <sequenceFlow id="flow2" sourceRef="roleGateway" targetRef="investigateCase">
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${role == 'SUPERVISOR'}]]></conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow3" sourceRef="roleGateway" targetRef="approveCase">
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${role != 'SUPERVISOR'}]]></conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flow4" sourceRef="investigateCase" targetRef="endEvent"/>
    <sequenceFlow id="flow5" sourceRef="approveCase" targetRef="endEvent"/>

  </process>
</definitions>
