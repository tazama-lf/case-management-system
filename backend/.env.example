#Database
DATABASE_URL="postgresql://postgres:tazamadb@10.10.80.31:5432/tazama"

#Alert Triage
TRIAGE_TYPE=MANUAL #(AI, MANUAL, DISABLED)
CONFIDENCE_THRESHOLD=95
CLIENT_SYSTEM_INTERDICTION_ENABLED=true
SYSTEM_UUID=a9a8ff94-c7e4-4e6c-b421-e6d5d75a76e1


#Auth
TAZAMA_AUTH_URL=http://localhost:3020/v1/auth/login 
AUTH_PUBLIC_KEY_PATH=public-key.pem
CERT_PATH_PUBLIC=public-key.pem
KEYCLOAK_GROUP_NAME=cms

# Flowable Configuration
FLOWABLE_URL=http://10.10.80.30:8081/flowable-rest

FLOWABLE_USERNAME=rest-admin
FLOWABLE_PASSWORD=test

# NATS Server
SERVER_URL=nats://10.10.80.30:4222
STARTUP_TYPE=nats
NODE_ENV=dev
FUNCTION_NAME=relay-service
PRODUCER_STREAM=default
CONSUMER_STREAM=cms

# Performance
MAX_CPU=1
#SIDECAR_HOST=0.0.0.0:5000

# Alert Priority
PRIORITY_FIRST_HALF=0.33
PRIORITY_SECOND_HALF=0.66
PRIORITY_THIRD_HALF=1.0
DEFAULT_SLA_HOURS=72
ALERT_PRIORITY_CRON_SCHEDULE=0 * * * *

# Auto-assignment (disabled for MVP)
AUTO_ASSIGNMENT_ENABLED=false

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="CMS Notifications" <no-reply@cms.local>

COUCHDB_URL=http://localhost:5984
COUCHDB_DATABASE=cms-evidence
COUCHDB_USERNAME=admin
COUCHDB_PASSWORD=admin
