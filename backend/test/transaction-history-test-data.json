  "howToTest": {
    "step1": "Start the backend server",
    "command1": "cd backend && npm run start:dev",
    
    "step2": "Open Swagger UI",
    "url2": "http://localhost:3000/api",
    
    "step3": "Authenticate",
    "description3": "Use the /api/v1/auth/login endpoint to get a JWT token, then click 'Authorize' button and paste the token",
    
    "step4": "Find the endpoint",
    "description4": "Look for 'Gold Lakehouse' section, find 'GET /api/v1/lakehouse/transaction-history/{entityId}'",
    
    "step5": "Click 'Try it out'",
    
    "step6": "Fill in parameters",
    "parameters6": {
      "entityId": "cdtrAcct_9e6fccad1b1b4850a6e90f548207748b",
      "startDate": "2026-01-13",
      "endDate": "2026-01-13",
      "granularity": "day",
      "tenantId": "DEFAULT"
    },
    
    "step7": "Click 'Execute'",
    
    "step8": "Verify response",
    "expectedSections": [
      "summary (with statistics)",
      "timeline (array of transactions)",
      "cumulative (running totals)",
      "volumeDistribution (bucketed data)",
      "recentTransactions (table data)",
      "meta (metadata)"
    ]
  },
  
  "troubleshooting": {
    "error401": {
      "message": "Unauthorized",
      "solution": "Make sure you have a valid JWT token. Login first at /api/v1/auth/login"
    },
    "error400DateFormat": {
      "message": "Invalid date format",
      "solution": "Use YYYY-MM-DD format for startDate and endDate"
    },
    "error400Granularity": {
      "message": "Invalid granularity",
      "solution": "Use one of: day, week, month, year"
    },
    "error500": {
      "message": "Internal Server Error",
      "solution": "Check backend logs. Ensure Gold Lakehouse API is running at http://10.10.80.20:8001"
    },
    "emptyData": {
      "message": "Response has empty arrays",
      "solution": "The entity_id may not have transactions in the specified date range. Try a different entity or date range"
    }
  }
